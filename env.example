# Telegram Bot token (от @BotFather)
BOT_TOKEN=

# Anthropic API key
ANTHROPIC_API_KEY=

# PostgreSQL connection string (Railway вставляет автоматически)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Telegram ID владельца (куда слать уведомления о проверках)
OWNER_TELEGRAM_ID=5089980481

# Telegram username владельца (без @) для кнопки CTA в отчёте
OWNER_TELEGRAM_USERNAME=

# Google PageSpeed Insights API key (опционально, без ключа работает с лимитом)
PAGESPEED_API_KEY=

# Короткое представление владельца в CTA-сообщении (2-3 строки)
# Пример: Александр — фронтенд-разработчик, 5 лет опыта, 30+ сайтов. Портфолио: example.com
OWNER_BIO=
